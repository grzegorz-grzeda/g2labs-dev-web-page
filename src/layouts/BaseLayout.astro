---
import { company, links } from "../data/company";
import { googleAnalyticsId, isGoogleAnalyticsConfigured } from "../lib/analytics";

interface Props {
    title: string;
    description: string;
}

const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const linkedInLink = links.find((link) => link.label === "LinkedIn")?.href;
const gitHubLink = links.find((link) => link.label === "GitHub")?.href;
const facebookLink = links.find((link) => link.label === "Facebook")?.href;
---

<!doctype html>
<html lang="en">
    <head>
        <script is:inline>
            (() => {
                const storageKey = "g2labs-theme";
                const validThemes = new Set(["light", "dark", "system"]);
                const getStoredTheme = () => {
                    try {
                        return localStorage.getItem(storageKey);
                    } catch {
                        return null;
                    }
                };
                const storedTheme = getStoredTheme();
                const themeChoice = validThemes.has(storedTheme)
                    ? storedTheme
                    : "system";
                const systemIsDark = window.matchMedia(
                    "(prefers-color-scheme: dark)",
                ).matches;
                const resolvedTheme =
                    themeChoice === "system"
                        ? systemIsDark
                            ? "dark"
                            : "light"
                        : themeChoice;

                document.documentElement.dataset.theme = resolvedTheme;
                document.documentElement.dataset.themeChoice = themeChoice;
                document.documentElement.style.colorScheme = resolvedTheme;
            })();
        </script>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <link rel="canonical" href={canonical} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Bree+Serif&family=Space+Grotesk:wght@400;500;700&display=swap"
            rel="stylesheet"
        />
        <title>{title}</title>
    </head>
    <body>
        <div class="page-shell">
            <header class="site-header">
                <div class="site-header-meta">
                    <span>{company.location}</span>
                    <span>Embedded systems, IoT, software</span>
                    <span>AI-assisted workflow</span>
                </div>
                <div class="site-header-shell panel">
                    <a class="brand" href="/">
                        <img
                            class="brand-logo"
                            src="/logo.png"
                            alt="G2Labs logo"
                            width="68"
                            height="68"
                        />
                        <span class="brand-copy">
                            <strong>G2Labs Grzegorz Grzęda</strong>
                            <span>Embedded-first engineering from Poland</span>
                        </span>
                    </a>
                    <div class="header-actions">
                        <nav class="site-nav" aria-label="Primary">
                            <div class="site-nav-primary">
                                <a href="/work">Work</a>
                                <a class="site-nav-cta" href="/contact">Contact</a>
                            </div>
                            <div class="site-nav-secondary">
                                <a href="/products">Products</a>
                                <a href="/tech-stack">Tech Stack</a>
                                <a href="/blog">Blog</a>
                            </div>
                        </nav>
                        <div
                            class="theme-switch"
                            role="group"
                            aria-label="Color theme"
                        >
                            <button
                                type="button"
                                data-theme-option="light"
                                aria-pressed="false">Light</button
                            >
                            <button
                                type="button"
                                data-theme-option="dark"
                                aria-pressed="false">Dark</button
                            >
                            <button
                                type="button"
                                data-theme-option="system"
                                aria-pressed="false">System</button
                            >
                        </div>
                    </div>
                </div>
            </header>
            <main>
                <slot />
            </main>
            <footer class="site-footer">
                <a class="footer-brand" href="/">
                    <img
                        class="footer-logo"
                        src="/logo.png"
                        alt="G2Labs logo"
                        width="150"
                        height="58"
                    />
                </a>
                <div>
                    <p>
                        G2Labs delivers firmware, IoT integrations, utility
                        software, and technical execution for connected
                        products.
                    </p>
                    <div class="footer-socials" aria-label="Social links">
                        {
                            linkedInLink && (
                                <a
                                    href={linkedInLink}
                                    target="_blank"
                                    rel="noreferrer"
                                    aria-label="LinkedIn"
                                >
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path
                                            d="M6.94 8.5A1.56 1.56 0 1 1 6.94 5.38a1.56 1.56 0 0 1 0 3.12ZM5.6 9.7h2.67V18H5.6V9.7Zm4.34 0h2.56v1.13h.04c.36-.68 1.23-1.4 2.53-1.4 2.7 0 3.2 1.77 3.2 4.07V18H15.6v-3.99c0-.95-.02-2.17-1.32-2.17-1.32 0-1.52 1.03-1.52 2.1V18H9.94V9.7Z"
                                            fill="currentColor"
                                        />
                                    </svg>
                                </a>
                            )
                        }
                        {
                            gitHubLink && (
                                <a
                                    href={gitHubLink}
                                    target="_blank"
                                    rel="noreferrer"
                                    aria-label="GitHub"
                                >
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path
                                            d="M12 2C6.48 2 2 6.6 2 12.26c0 4.52 2.87 8.35 6.84 9.7.5.1.68-.22.68-.49 0-.24-.01-1.05-.01-1.91-2.78.62-3.37-1.21-3.37-1.21-.46-1.19-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .08 1.53 1.06 1.53 1.06.9 1.57 2.36 1.11 2.94.85.09-.67.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.28 2.75 1.05A9.31 9.31 0 0 1 12 6.93c.85 0 1.71.12 2.52.36 1.91-1.33 2.75-1.05 2.75-1.05.55 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.58 5.06.36.32.68.95.68 1.92 0 1.39-.01 2.5-.01 2.84 0 .27.18.6.69.49A10.27 10.27 0 0 0 22 12.26C22 6.6 17.52 2 12 2Z"
                                            fill="currentColor"
                                        />
                                    </svg>
                                </a>
                            )
                        }
                        {
                            facebookLink && (
                                <a
                                    href={facebookLink}
                                    target="_blank"
                                    rel="noreferrer"
                                    aria-label="Facebook"
                                >
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path
                                            d="M13.5 22v-8h2.7l.4-3h-3.1V9.1c0-.87.25-1.46 1.5-1.46H17V4.96c-.37-.05-1.16-.16-2.2-.16-2.18 0-3.67 1.33-3.67 3.77V11H8.5v3h2.63v8h2.37Z"
                                            fill="currentColor"
                                        />
                                    </svg>
                                </a>
                            )
                        }
                    </div>
                    <div class="footer-legal-links" aria-label="Legal links">
                        <a href="/privacy">Privacy notice</a>
                        <a href="/terms">Terms of use</a>
                        <button type="button" data-cookie-consent-settings>
                            Cookie settings
                        </button>
                    </div>
                    <p>{company.location}</p>
                </div>
            </footer>
        </div>
        <div
            class="cookie-consent"
            data-cookie-consent
            hidden
            role="region"
            aria-label="Cookie consent"
        >
            <div class="cookie-consent-copy">
                <p class="cookie-consent-title">Analytics consent</p>
                <p>
                    G2Labs can use Google Analytics to understand site usage.
                    Declining keeps analytics disabled. You can read more in the
                    <a href="/privacy">privacy notice</a>.
                </p>
            </div>
            <div class="cookie-consent-actions">
                <button
                    class="button button-secondary"
                    type="button"
                    data-cookie-consent-decline
                >
                    Decline
                </button>
                <button
                    class="button button-primary"
                    type="button"
                    data-cookie-consent-accept
                >
                    Accept analytics
                </button>
            </div>
        </div>
        <script
            is:inline
            define:vars={{ googleAnalyticsId, isGoogleAnalyticsConfigured }}
        >
            (() => {
                const storageKey = "g2labs-cookie-consent";
                const banner = document.querySelector("[data-cookie-consent]");
                const acceptButton = document.querySelector(
                    "[data-cookie-consent-accept]",
                );
                const declineButton = document.querySelector(
                    "[data-cookie-consent-decline]",
                );
                const settingsButton = document.querySelector(
                    "[data-cookie-consent-settings]",
                );

                const getConsent = () => {
                    try {
                        return localStorage.getItem(storageKey);
                    } catch {
                        return null;
                    }
                };

                const setConsent = (choice) => {
                    try {
                        localStorage.setItem(storageKey, choice);
                    } catch {
                        return;
                    }
                };

                const loadAnalytics = () => {
                    if (
                        window.g2labsAnalyticsLoaded ||
                        !isGoogleAnalyticsConfigured
                    ) {
                        return;
                    }

                    window.g2labsAnalyticsLoaded = true;
                    window.dataLayer = window.dataLayer || [];
                    window.gtag = function gtag() {
                        window.dataLayer.push(arguments);
                    };
                    window.gtag("js", new Date());
                    window.gtag("config", googleAnalyticsId);

                    const script = document.createElement("script");
                    script.async = true;
                    script.src = `https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`;
                    document.head.appendChild(script);
                };

                const hideBanner = () => {
                    if (banner) {
                        banner.hidden = true;
                    }
                };

                const showBanner = () => {
                    if (banner) {
                        banner.hidden = false;
                    }
                };

                const storedConsent = getConsent();

                if (storedConsent === "accepted") {
                    loadAnalytics();
                    hideBanner();
                } else if (storedConsent === "declined") {
                    hideBanner();
                } else {
                    showBanner();
                }

                acceptButton?.addEventListener("click", () => {
                    setConsent("accepted");
                    loadAnalytics();
                    hideBanner();
                });

                declineButton?.addEventListener("click", () => {
                    setConsent("declined");
                    hideBanner();
                });

                settingsButton?.addEventListener("click", showBanner);
            })();
        </script>
        <script is:inline>
            (() => {
                const storageKey = "g2labs-theme";
                const validThemes = new Set(["light", "dark", "system"]);
                const getStoredTheme = () => {
                    try {
                        return localStorage.getItem(storageKey);
                    } catch {
                        return null;
                    }
                };
                const setStoredTheme = (themeChoice) => {
                    try {
                        localStorage.setItem(storageKey, themeChoice);
                    } catch {
                        return;
                    }
                };
                const mediaQuery = window.matchMedia(
                    "(prefers-color-scheme: dark)",
                );
                const buttons = [...document.querySelectorAll("[data-theme-option]")];

                const resolveTheme = (themeChoice) => {
                    if (themeChoice === "system") {
                        return mediaQuery.matches ? "dark" : "light";
                    }

                    return themeChoice;
                };

                const applyTheme = (themeChoice) => {
                    const nextChoice = validThemes.has(themeChoice)
                        ? themeChoice
                        : "system";
                    const resolvedTheme = resolveTheme(nextChoice);

                    document.documentElement.dataset.theme = resolvedTheme;
                    document.documentElement.dataset.themeChoice = nextChoice;
                    document.documentElement.style.colorScheme = resolvedTheme;

                    buttons.forEach((button) => {
                        const isActive =
                            button.dataset.themeOption === nextChoice;
                        button.classList.toggle("is-active", isActive);
                        button.setAttribute("aria-pressed", String(isActive));
                    });
                };

                buttons.forEach((button) => {
                    button.addEventListener("click", () => {
                        const nextChoice = button.dataset.themeOption || "system";
                        setStoredTheme(nextChoice);
                        applyTheme(nextChoice);
                    });
                });

                mediaQuery.addEventListener("change", () => {
                    const storedTheme = getStoredTheme();
                    const themeChoice = validThemes.has(storedTheme)
                        ? storedTheme
                        : "system";
                    applyTheme(themeChoice);
                });

                const storedTheme = getStoredTheme();
                applyTheme(validThemes.has(storedTheme) ? storedTheme : "system");
            })();
        </script>
    </body>
</html>

<style is:global>
    @import "../styles/global.css";
</style>
