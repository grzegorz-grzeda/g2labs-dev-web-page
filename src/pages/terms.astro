---
import { business, company } from "../data/company";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Terms of Use | G2Labs"
    description="Terms of use for g2labs.dev covering website content, external links, and general use of the site."
>
    <section class="page-intro panel">
        <p class="eyebrow">Terms of use</p>
        <h1>
            Basic terms for using the G2Labs website.
        </h1>
        <p class="lead">
            These terms apply to your use of {company.site} and the information
            published there by {business.companyName}.
        </p>
    </section>

    <section class="panel panel-shell prose">
        <h2>Purpose of the site</h2>
        <p>
            This website presents G2Labs services, experience, product work,
            articles, and contact routes. The content is provided for general
            information and business communication.
        </p>

        <h2>Use of the site</h2>
        <p>
            You may browse, read, and contact G2Labs through the site for lawful
            purposes. You should not use the site in a way that interferes with
            its operation, attempts unauthorized access, or abuses the contact
            forms.
        </p>

        <h2>Content and accuracy</h2>
        <p>
            G2Labs aims to keep the site content accurate and current, but the
            website is provided on an as-available basis. Project summaries,
            technical examples, and service descriptions are informational and
            do not by themselves form a binding offer or guarantee.
        </p>

        <h2>External links</h2>
        <p>
            The site may link to external platforms and public registries.
            G2Labs is not responsible for the content, availability, or terms of
            those third-party services.
        </p>

        <h2>Intellectual property</h2>
        <p>
            Unless stated otherwise, the text, structure, branding, and original
            site content belong to G2Labs or are used with permission. Do not
            copy or republish substantial parts of the site as your own work.
        </p>

        <h2>No professional reliance without agreement</h2>
        <p>
            Nothing on this site creates a client relationship, engineering
            engagement, or formal advisory obligation until that relationship is
            explicitly agreed.
        </p>

        <h2>Changes</h2>
        <p>
            G2Labs may update, remove, or revise site content and these terms at
            any time when the business, services, or legal requirements change.
        </p>
    </section>
</BaseLayout>