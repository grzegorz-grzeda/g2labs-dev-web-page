---
import { products } from "../../data/company";
import BaseLayout from "../../layouts/BaseLayout.astro";

const productScreenshotMap = {
    vt100logging: {
        src: "/vt100logging.png",
        alt: "vt100logging terminal screenshot",
        width: 1000,
        height: 700,
        frameClass: "product-screenshot-frame-compact",
    },
    devtoolsforme: {
        src: "/devtoolsforme.png",
        alt: "DevToolsForMe homepage screenshot",
        width: 1920,
        height: 1459,
        frameClass: "product-screenshot-frame-compact",
    },
    micros: {
        src: "/microsproject.png",
        alt: "MicrOS website screenshot",
        width: 1920,
        height: 1187,
        frameClass:
            "product-screenshot-frame-compact product-screenshot-frame-micros-compact",
    },
} as const;
---

<BaseLayout
    title="Products | G2Labs"
    description="Selected products by G2Labs, including browser-side developer tooling and the MicrOS open-source embedded operating system."
>
    <section class="page-intro panel">
        <p class="eyebrow">Products</p>
        <h1>Product work that makes the engineering taste visible.</h1>
        <p class="lead">
            These products show two sides of the same delivery style: fast,
            useful software surfaces for engineers and clear, low-level embedded
            systems work in public.
        </p>
    </section>

    <section class="project-grid work-grid">
        {
            products.map((product) => {
                const screenshot =
                    productScreenshotMap[
                        product.slug as keyof typeof productScreenshotMap
                    ];
                const secondaryHref =
                    "repo" in product && product.repo ? product.repo : product.href;
                const secondaryLabel =
                    product.slug === "vt100logging"
                        ? "Open package"
                        : "Open live project";

                return (
                    <article class="project-card tall-card">
                        {screenshot && (
                            <figure
                                class={`product-screenshot-frame ${screenshot.frameClass}`}
                            >
                                <img
                                    src={screenshot.src}
                                    alt={screenshot.alt}
                                    loading="lazy"
                                    width={screenshot.width}
                                    height={screenshot.height}
                                />
                            </figure>
                        )}
                        <p class="card-kicker">{product.label}</p>
                        <h2>{product.name}</h2>
                        <p>{product.summary}</p>
                        <p class="service-outcome">{product.story}</p>
                        <div class="tag-row stack-tags">
                            {product.categories.slice(0, 5).map((category) => (
                                <span>{category}</span>
                            ))}
                        </div>
                        <div class="product-links">
                            <a
                                class="button button-primary"
                                href={`/products/${product.slug}`}
                            >
                                View product page
                            </a>
                            <a
                                class="button button-secondary"
                                href={secondaryHref}
                                target="_blank"
                                rel="noreferrer"
                            >
                                {secondaryLabel}
                            </a>
                        </div>
                    </article>
                );
            })
        }
    </section>
</BaseLayout>
