---
import {
    awards,
    caseStudies,
    clients,
    education,
    experience,
    publications,
    services,
    techStack,
} from "../data/company";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Work | G2Labs"
    description="Selected service areas, client profile, and engineering engagement model for G2Labs."
>
    <section class="page-intro panel">
        <p class="eyebrow">Work</p>
        <h1>
            Case studies and offers for teams that need one technical thread
            across firmware, integration, and delivery.
        </h1>
        <p class="lead">
            G2Labs is most useful where the hard part is not a single module,
            but the boundary between the device, the software around it, and the
            need to actually ship.
        </p>
    </section>

    <section class="project-grid work-grid">
        {
            services.map((offering) => (
                <article class="project-card tall-card">
                    <p class="card-kicker">{offering.format}</p>
                    <h2>{offering.title}</h2>
                    <p>{offering.description}</p>
                    <p class="service-outcome">{offering.outcome}</p>
                    <ul class="service-deliverables">
                        {offering.deliverables.map((item) => (
                            <li>{item}</li>
                        ))}
                    </ul>
                </article>
            ))
        }
    </section>

    <section class="panel panel-shell market-fit-strip">
        <div>
            <p class="eyebrow">Engagement profile</p>
            <h2>
                Most useful where delivery risk lives between device logic,
                connectivity, and the software stack around the product.
            </h2>
        </div>
        <div class="fit-points">
            <p>
                Established companies: embedded execution, technical leadership
                on implementation slices, and integration-heavy product work.
            </p>
            <p>
                Startups and MVPs: early architecture and practical delivery
                when a connected product cannot wait for separate specialist
                tracks.
            </p>
        </div>
    </section>

    <section class="panel panel-shell">
        <div class="section-heading compact-heading">
            <div>
                <p class="eyebrow">Experience timeline</p>
                <h2>
                    A direct overview of the companies, periods, and delivery
                    areas behind the work.
                </h2>
            </div>
        </div>
        <div class="experience-list detailed-experience-list">
            {
                experience.map((entry) => (
                    <article class="experience-item detailed-experience-item">
                        <div class="experience-period">{entry.period}</div>
                        <div class="experience-content">
                            <p class="card-kicker">{entry.company}</p>
                            <h3>{entry.role}</h3>
                            <p>{entry.summary}</p>
                            <ul class="experience-highlights">
                                {entry.highlights.map((item) => (
                                    <li>{item}</li>
                                ))}
                            </ul>
                        </div>
                    </article>
                ))
            }
        </div>
    </section>

    <section class="panel panel-shell">
        <div class="section-heading compact-heading">
            <div>
                <p class="eyebrow">Case studies</p>
                <h2>
                    These are the kinds of situations where G2Labs is most
                    useful: product boundaries, embedded delivery pressure, and
                    software around the device that still has to make sense.
                </h2>
            </div>
        </div>
        <div
            class="case-study-list case-study-row-list case-study-row-list-detailed"
        >
            {
                caseStudies.map((study) => (
                    <article class="panel blog-list-item case-study-detail case-study-row-card case-study-row-card-detailed">
                        <p class="card-kicker case-study-row-label">
                            {study.client} / {study.period}
                        </p>
                        <div class="case-study-row-content case-study-row-content-detailed">
                            <h2>{study.title}</h2>
                            <p class="case-study-meta">
                                <strong>Context:</strong> {study.context}
                            </p>
                            <p>{study.challenge}</p>
                            <div class="tag-row stack-tags case-study-stack-tags">
                                {study.stack.map((item) => (
                                    <span>{item}</span>
                                ))}
                            </div>
                            <p class="case-study-meta">
                                <strong>What I owned:</strong> {study.ownership}
                            </p>
                            <ul class="case-study-points">
                                {study.work.map((item) => (
                                    <li>{item}</li>
                                ))}
                            </ul>
                            <p>{study.outcome}</p>
                            <ul class="stack-examples case-study-proof-points">
                                {study.proofPoints.map((item) => (
                                    <li>{item}</li>
                                ))}
                            </ul>
                        </div>
                    </article>
                ))
            }
        </div>
    </section>

    <section class="panel panel-shell">
        <div class="section-heading compact-heading">
            <div>
                <p class="eyebrow">Credentials</p>
                <h2>
                    Education, awards, and publications that support the
                    engineering background behind the delivery work.
                </h2>
            </div>
        </div>
        <div class="credentials-grid">
            <article class="project-card credential-card">
                <p class="card-kicker">Education</p>
                <h3>Academic training</h3>
                <ul class="credential-list">
                    {
                        education.map((item) => (
                            <li>
                                <strong>{item.degree}</strong>
                                <span>
                                    {item.institution} · {item.period}
                                </span>
                            </li>
                        ))
                    }
                </ul>
            </article>
            <article class="project-card credential-card">
                <p class="card-kicker">Awards</p>
                <h3>Recognition</h3>
                <ul class="credential-list">
                    {awards.map((item) => <li>{item}</li>)}
                </ul>
            </article>
            <article class="project-card credential-card">
                <p class="card-kicker">Publications</p>
                <h3>Publications</h3>
                <ul class="credential-list">
                    {publications.map((item) => <li>{item}</li>)}
                </ul>
            </article>
        </div>
    </section>

    <section class="panel panel-shell">
        <div class="section-heading compact-heading">
            <div>
                <p class="eyebrow">Tech stack used in delivery</p>
                <h2>
                    Tools and platforms used in actual product work, grouped by
                    the kind of problem they helped solve.
                </h2>
            </div>
            <a href="/tech-stack">Open the full stack page</a>
        </div>
        <div class="stack-grid">
            {
                techStack.map((group) => (
                    <article class="project-card stack-card">
                        <h3>{group.area}</h3>
                        <p>{group.summary}</p>
                        <div class="tag-row stack-tags">
                            {group.items.map((item) => (
                                <span>{item}</span>
                            ))}
                        </div>
                        <ul class="stack-examples">
                            {group.examples.map((example) => (
                                <li>{example}</li>
                            ))}
                        </ul>
                    </article>
                ))
            }
        </div>
    </section>

    <section class="panel panel-shell">
        <div class="section-heading compact-heading">
            <div>
                <p class="eyebrow">Client fit</p>
                <h2>
                    Mostly aimed at established product teams, with enough range
                    to help a startup MVP when the scope is sharp and the
                    bottleneck is real.
                </h2>
            </div>
        </div>
        <div class="tag-row client-row">
            {clients.map((client) => <span>{client}</span>)}
        </div>
    </section>

    <section class="split-section">
        <div>
            <p class="eyebrow">Engagement model</p>
            <h2>One builder, one technical thread, less translation loss.</h2>
        </div>
        <div class="panel panel-shell">
            <p>
                Discovery stays light, implementation is direct, and the work is
                sliced around the biggest technical risk instead of presentation
                overhead.
            </p>
            <p>
                AI is used where it shortens loops without hiding decisions:
                research support, scaffolding, documentation, and internal
                tooling. The final engineering choices still stay explicit,
                reviewable, and tied to the product context.
            </p>
        </div>
    </section>
</BaseLayout>
