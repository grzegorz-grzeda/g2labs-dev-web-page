---
import { getCollection } from "astro:content";
import {
    business,
    caseStudies,
    clients,
    company,
    experience,
    links,
    projects,
    services,
    techStack,
} from "../data/company";
import BaseLayout from "../layouts/BaseLayout.astro";

const herotofuEndpoint = import.meta.env.PUBLIC_HEROTOFU_ENDPOINT;
const isFormConfigured = Boolean(herotofuEndpoint);
const homeContactLinks = links.filter((link) =>
    ["LinkedIn", "GitHub", "Facebook", "CEIDG registry"].includes(link.label),
);

const blogPosts = (await getCollection("blog", ({ data }) => !data.draft))
    .sort(
        (left, right) =>
            right.data.publishDate.getTime() - left.data.publishDate.getTime(),
    )
    .slice(0, 2);

const distilledTechStack = techStack.map((group) => ({
    ...group,
    items: group.items.slice(0, 4),
}));

const getPostHref = (id: string) => `/blog/${id.replace(/\.(md|mdx)$/, "")}/`;
---

<BaseLayout
    title="G2Labs | Embedded systems and connected software from Poland"
    description="G2Labs is an embedded-first engineering practice from Poland, delivering firmware, IoT integrations, software tooling, and AI-assisted product delivery."
>
    <section class="hero panel">
        <div>
            <p class="eyebrow">Connected-product delivery from Poland</p>
            <h1>
                Ship connected products without splitting firmware, integration,
                and product software into separate delivery tracks.
            </h1>
            <p class="lead">
                {company.description} The strongest fit is delivery-critical work:
                firmware rescue, device-to-software integration, and MVP or product
                work where one engineer needs to keep the technical thread intact
                end to end.
            </p>
            <div class="hero-actions">
                <a class="button button-primary" href="/contact"
                    >Start a conversation</a
                >
                <a class="button button-secondary" href="/work"
                    >See selected work</a
                >
            </div>
        </div>
        <div class="hero-card">
            <p>Why teams bring in G2Labs</p>
            <ul>
                <li>
                    One engineering thread from firmware through integration
                </li>
                <li>
                    Useful in rescue, delivery, and integration-heavy product
                    work
                </li>
                <li>Hands-on execution without agency-style layers</li>
            </ul>
        </div>
    </section>

    <section class="signal-grid">
        <article class="panel signal">
            <span>01</span>
            <h2>Embedded depth</h2>
            <p>
                Firmware, RTOS work, wireless systems, and hardware-adjacent
                engineering grounded in actual product delivery.
            </p>
        </article>
        <article class="panel signal">
            <span>02</span>
            <h2>Software range</h2>
            <p>
                Desktop, backend, web integrations, and utility tooling that
                connect devices to the rest of the product stack.
            </p>
        </article>
        <article class="panel signal">
            <span>03</span>
            <h2>Pragmatic AI workflow</h2>
            <p>
                AI helps accelerate research, prototyping, and documentation,
                but the engineering decisions still stay explicit and
                reviewable.
            </p>
        </article>
    </section>

    <section class="panel panel-shell">
        <div class="section-heading compact-heading">
            <div>
                <p class="eyebrow">Selected companies</p>
                <h2>
                    Experience shaped in product teams that ship beyond
                    prototype stage.
                </h2>
            </div>
        </div>
        <div class="tag-row client-row">
            {clients.map((client) => <span>{client}</span>)}
        </div>
    </section>

    <section class="panel panel-shell about-strip">
        <div class="section-heading compact-heading">
            <div>
                <p class="eyebrow">About the studio</p>
                <h2>
                    Operating from Poland, built for clients who need one
                    engineer to understand the device, the software around it,
                    and the path to delivery.
                </h2>
            </div>
        </div>
        <div class="about-studio-grid">
            <figure class="about-portrait">
                <img
                    src="/me-2.jpeg"
                    alt="Grzegorz Grzęda"
                    loading="lazy"
                    width="896"
                    height="1152"
                />
            </figure>
            <div class="about-copy">
                <p>
                    {company.longBio}
                </p>
                <p>
                    Public work includes MicrOS, power electronics experiments,
                    embedded tooling, and developer-facing software projects.
                    The same practical approach carries into client delivery.
                </p>
            </div>
        </div>
    </section>

    <section class="panel panel-shell">
        <div class="section-heading compact-heading">
            <div>
                <p class="eyebrow">Experience timeline</p>
                <h2>
                    A concise view of where the work happened and what kind of
                    engineering sat behind it.
                </h2>
            </div>
            <a href="/work">See the full work page</a>
        </div>
        <div class="experience-list">
            {
                experience.map((entry) => (
                    <article class="experience-item">
                        <div class="experience-period">{entry.period}</div>
                        <div class="experience-content">
                            <p class="card-kicker">{entry.company}</p>
                            <h3>{entry.role}</h3>
                            <p>{entry.summary}</p>
                        </div>
                    </article>
                ))
            }
        </div>
    </section>

    <section class="panel panel-shell market-fit-strip">
        <div>
            <p class="eyebrow">Best fit</p>
            <h2>
                Built for established teams, still useful when a startup MVP
                needs to cross hardware and software boundaries fast.
            </h2>
        </div>
        <div class="fit-points">
            <p>
                Medium and large companies needing firmware ownership,
                integration clarity, or delivery support.
            </p>
            <p>
                Startup teams building an MVP where embedded, backend, and
                interface layers cannot be split into separate tracks.
            </p>
        </div>
    </section>

    <section class="panel panel-shell">
        <div class="section-heading compact-heading">
            <div>
                <p class="eyebrow">Offers</p>
                <h2>
                    Hire G2Labs when product risk sits at the boundary between
                    the device and everything around it.
                </h2>
            </div>
            <a href="/work">See the full work page</a>
        </div>
        <div class="project-grid work-grid">
            {
                services.map((service) => (
                    <article class="project-card tall-card">
                        <p class="card-kicker">{service.format}</p>
                        <h3>{service.title}</h3>
                        <p>{service.description}</p>
                        <p class="service-outcome">{service.outcome}</p>
                    </article>
                ))
            }
        </div>
    </section>

    <section class="panel panel-shell">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Case studies</p>
                <h2>
                    Representative examples of where firmware ownership, product
                    integration, and delivery pressure had to stay in the same
                    conversation.
                </h2>
            </div>
            <a href="/work">Open the work page</a>
        </div>
        <div class="case-study-grid">
            {
                caseStudies.map((study) => (
                    <article class="project-card case-study-card">
                        <p class="card-kicker">
                            {study.client} / {study.period}
                        </p>
                        <h3>{study.title}</h3>
                        <p>{study.challenge}</p>
                        <p class="service-outcome">{study.outcome}</p>
                    </article>
                ))
            }
        </div>
    </section>

    <section class="panel panel-shell">
        <div class="section-heading compact-heading">
            <div>
                <p class="eyebrow">Distilled tech stack</p>
                <h2>
                    Core tools and platforms used across firmware delivery,
                    product integration, and the software around the device.
                </h2>
            </div>
            <a href="/tech-stack">Open the full stack page</a>
        </div>
        <div class="stack-grid">
            {
                distilledTechStack.map((group) => (
                    <article class="project-card stack-card">
                        <h3>{group.area}</h3>
                        <p>{group.summary}</p>
                        <div class="tag-row stack-tags">
                            {group.items.map((item) => <span>{item}</span>)}
                        </div>
                    </article>
                ))
            }
        </div>
    </section>

    <section class="panel panel-shell casual-note-strip">
        <div class="casual-note-copy">
            <p class="eyebrow">Behind the work</p>
            <h2>
                Independent, hands-on, and usually working close to the real
                product constraints rather than far above them.
            </h2>
            <p>
                G2Labs stays intentionally small. That keeps communication
                direct, engineering decisions explicit, and the work close to
                the actual device and software behavior that teams have to ship.
            </p>
        </div>
        <figure class="panel casual-portrait">
            <img
                src="/me-1.jpeg"
                alt="Grzegorz Grzęda in a casual portrait"
                loading="lazy"
                width="896"
                height="1152"
            />
        </figure>
    </section>

    <section class="panel panel-shell home-contact-strip">
        <div class="home-contact-copy">
            <p class="eyebrow">Contact</p>
            <h2>
                Reach out through LinkedIn, GitHub, the public CEIDG entry, or
                send a short inquiry directly from the homepage.
            </h2>
            <div class="home-contact-links">
                {
                    homeContactLinks.map((link) => (
                        <a href={link.href} target="_blank" rel="noreferrer">
                            <span>{link.label}</span>
                            <span>
                                {link.label === "CEIDG registry"
                                    ? "Registry"
                                    : "Profile"}
                            </span>
                        </a>
                    ))
                }
            </div>
            <div class="trust-mini-block">
                <p><strong>{business.companyName}</strong></p>
                <p>NIP {business.nip} · REGON {business.regon}</p>
                <p>
                    Active since {business.started} · {business.responseWindow}
                </p>
            </div>
        </div>
        <form
            class="contact-form compact-contact-form"
            method="POST"
            action={isFormConfigured ? herotofuEndpoint : undefined}
        >
            <input
                type="hidden"
                name="_subject"
                value="Homepage inquiry from g2labs.dev"
            />
            <input
                type="text"
                name="_gotcha"
                class="form-honeypot"
                tabindex="-1"
                autocomplete="off"
            />

            <div class="form-grid compact-form-grid">
                <label>
                    <span>Name</span>
                    <input
                        type="text"
                        name="name"
                        autocomplete="name"
                        required
                    />
                </label>
                <label>
                    <span>Email</span>
                    <input
                        type="email"
                        name="email"
                        autocomplete="email"
                        required
                    />
                </label>
                <label class="field-full">
                    <span>What do you need help with?</span>
                    <textarea
                        name="problem"
                        rows="4"
                        placeholder="Firmware delivery, device integration, MVP planning, or another concrete product bottleneck."
                        required></textarea>
                </label>
            </div>

            <div class="form-actions compact-form-actions">
                <button
                    class="button button-primary"
                    type="submit"
                    disabled={!isFormConfigured}
                >
                    Send inquiry
                </button>
                <p class="form-note">
                    {
                        isFormConfigured
                            ? "The homepage form is active for this deployment."
                            : "Set PUBLIC_HEROTOFU_ENDPOINT to activate direct submissions."
                    }
                </p>
            </div>
        </form>
    </section>

    <section class="panel panel-shell">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Latest writing</p>
                <h2>
                    Notes on firmware, connected systems, and engineering
                    workflows that stay understandable.
                </h2>
            </div>
            <a href="/blog">Read the archive</a>
        </div>
        <div class="blog-grid">
            {
                blogPosts.map((post) => (
                    <article class="post-card">
                        <p>
                            {post.data.publishDate.toLocaleDateString("en-US", {
                                month: "short",
                                day: "numeric",
                                year: "numeric",
                            })}
                        </p>
                        <h3>
                            <a href={getPostHref(post.id)}>{post.data.title}</a>
                        </h3>
                        <p>{post.data.excerpt}</p>
                    </article>
                ))
            }
        </div>
    </section>
</BaseLayout>
